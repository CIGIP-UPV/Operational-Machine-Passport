{
  "id": null,
  "title": "OPC UA Genérico - Variables dinámicas",
  "tags": ["opcua", "prometheus", "dynamic"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "templating": {
    "list": [
      {
        "name": "display_name",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PROMETHEUS_DS_UID"
        },
        "refresh": 2,
        "query": "label_values(opcua_node_value, display_name)",
        "multi": true,
        "includeAll": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "$display_name",
      "id": 1,
      "repeat": "display_name",
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS_UID"
      },
      "targets": [
        {
          "expr": "opcua_node_value{display_name=\"$display_name\"}",
          "refId": "A",
          "legendFormat": "{{nodeid}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      }
    }
  ],
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m"
    ]
  }
}
