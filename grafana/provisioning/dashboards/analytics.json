{
  "id": null,
  "title": "Industrial Analytics",
  "tags": ["analytics", "opcua", "anomaly"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Anomaly Score",
      "id": 1,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "asset_anomaly_score",
          "refId": "A",
          "legendFormat": "{{asset_id}}/{{signal}}/{{detector}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Monitoring Confidence",
      "id": 2,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "asset_monitoring_confidence",
          "refId": "A",
          "legendFormat": "{{asset_id}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "type": "timeseries",
      "title": "Root Cause State",
      "id": 3,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "asset_root_cause_state",
          "refId": "A",
          "legendFormat": "{{asset_id}}/{{hint}}"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "type": "timeseries",
      "title": "Detector Vote Total",
      "id": 4,
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "asset_detector_vote_total",
          "refId": "A",
          "legendFormat": "{{asset_id}}/{{signal}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 18
      }
    }
  ],
  "time": {
    "from": "now-15m",
    "to": "now"
  }
}
