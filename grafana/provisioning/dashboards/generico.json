{
  "id": null,
  "title": "OPC-UA Variables (Dinámico)",
  "tags": ["opcua", "prometheus", "dynamic"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "$opcua_metric",
      "id": 1,
      "datasource": {
        "type": "prometheus",
        "uid": "PROMETHEUS_DS_UID"
      },
      "targets": [
        {
          "expr": "${opcua_metric}",
          "legendFormat": "{{opcua_metric}}",
          "refId": "A"
        }
      ],
      "repeat": "opcua_metric",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "opcua_metric",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "PROMETHEUS_DS_UID"
        },
        "refresh": 1,
        "query": "label_values({__name__=~\".*\"}, __name__)",
        "sort": 1,
        "multi": true,
        "includeAll": false
      }
    ]
  },
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m"
    ]
  }
}
